// Sindbad database schema.
// The domain model this implements lives in docs/02-domain-blueprint.md.
// Phase 1: Identity & Access (module 1). Later modules extend this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & Access ───────────────────────────

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum AccountType {
  PERSONAL
  COMMERCIAL
}

enum AccountRole {
  OWNER
  MANAGER
}

enum OtpPurpose {
  REGISTER
  LOGIN
  NEW_DEVICE
  SENSITIVE_ACTION
  PASSWORD_RESET
}

enum OtpChannel {
  SMS
  EMAIL
}

enum BlockedIdentityKind {
  PHONE
  NATIONAL_ID
  PASSPORT
  FULL_NAME
}

/// A login (credentials + security). The marketplace participant is `Account`.
model User {
  id              String     @id @default(cuid())
  email           String?    @unique
  phone           String?    @unique
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  passwordHash    String
  status          UserStatus @default(ACTIVE)
  isStaff         Boolean    @default(false)
  isSuperAdmin    Boolean    @default(false)
  totpSecret      String? // admin 2FA
  totpEnabledAt   DateTime? // set once the first code is verified; login then requires TOTP
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  memberships      AccountMember[]
  sessions         Session[]
  otpChallenges    OtpChallenge[]
  teamMemberships  TeamMember[]
  staffPermissions StaffPermission[]
}

/// The marketplace participant: profile, credibility, wallet, missions hang off this.
model Account {
  id                   String      @id @default(cuid())
  type                 AccountType @default(PERSONAL)
  displayName          String
  displayNameChangedAt DateTime?
  credibilityScore     Int         @default(0) // recomputed weekly; never shown below 0
  credibilityTier      String      @default("NEW") // NEW/BRONZE/SILVER/GOLD/PLATINUM
  flaggedForBlock      Boolean     @default(false) // raw score went negative (decision G3)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  members             AccountMember[]
  missions            Mission[]
  travelerDeals       Deal[]               @relation("travelerDeals")
  shopperDeals        Deal[]               @relation("shopperDeals")
  notifications       Notification[]
  categoryPreferences CategoryPreference[]
  verifications       Verification[]
  credibilityEvents   CredibilityEvent[]
}

// ── Trust: verification & credibility (docs/02 §8) ──

/// Admin-configurable verifiable details: price, duration, points (docs/02 §3).
model VerificationType {
  id                String   @id @default(cuid())
  key               String   @unique // FULL_NAME / PHONE / EMAIL / NATIONAL_ID / PHOTO_LIVENESS / …
  nameEn            String
  nameAr            String
  priceUsd          Int      @default(0) // minor units; paid from the wallet; KEPT on rejection
  credibilityPoints Int      @default(5)
  durationDays      Int      @default(3) // "how long does it take"
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  verifications Verification[]
}

enum VerificationStatus {
  NEW
  STUDYING
  VERIFIED
  NEEDS_REVIEW
  REJECTED
}

model Verification {
  id              String             @id @default(cuid())
  accountId       String
  typeId          String
  details         String?
  socialCode      String? // code-in-profile method for Facebook/Instagram (decision F3)
  status          VerificationStatus @default(NEW)
  points          Int                @default(0) // snapshot applied when VERIFIED
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  account Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type    VerificationType @relation(fields: [typeId], references: [id])

  @@index([accountId])
  @@index([status])
}

enum ReviewStatus {
  PENDING // blind — hidden from the other party
  REVEALED // both submitted, or the window closed (decision P1/#7)
}

/// Mutual deal reviews (docs/02 §8): blind until reveal; delete yes, edit no.
model Review {
  id              String       @id @default(cuid())
  dealId          String
  authorAccountId String
  targetAccountId String
  stars           Int // 1–5
  comment         String?
  status          ReviewStatus @default(PENDING)
  response        String? // the reviewed party's reply (after reveal)
  respondedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([dealId, authorAccountId])
  @@index([targetAccountId, status])
}

enum UserFlagKind {
  OUTSTANDING
  FOLLOW // priority in lists
  BLOCK // no contact, hidden activity, no matching — both ways
}

model UserFlag {
  ownerAccountId  String
  targetAccountId String
  kind            UserFlagKind
  createdAt       DateTime     @default(now())

  @@id([ownerAccountId, targetAccountId])
  @@index([targetAccountId, kind])
}

/// Favorites — quick recipients for money transfers (spec "Wallet").
model Favorite {
  ownerAccountId  String
  targetAccountId String
  createdAt       DateTime @default(now())

  @@id([ownerAccountId, targetAccountId])
}

/// Append-only credibility ledger. Weekly recompute derives Account.credibilityScore.
model CredibilityEvent {
  id           String   @id @default(cuid())
  accountId    String
  kind         String // VERIFICATION / TRIP / SHIPMENT / REVIEW / ADMIN
  points       Int
  timeWeighted Boolean  @default(true) // verifications & admin adjustments are not
  refId        String? // verificationId / dealId / reviewId
  note         String?
  createdAt    DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
}

/// User ↔ Account link. Personal = one OWNER; Commercial = OWNER + MANAGERs (full permissions in v1).
model AccountMember {
  userId    String
  accountId String
  role      AccountRole @default(OWNER)
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([userId, accountId])
  @@index([accountId])
}

/// One row per device/login. Refresh tokens rotate; only the hash is stored.
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  deviceLabel      String?
  ip               String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// OTP step-up: registration, new device, sensitive actions, password reset.
model OtpChallenge {
  id          String     @id @default(cuid())
  userId      String?
  destination String // normalized email or phone
  channel     OtpChannel
  purpose     OtpPurpose
  codeHash    String
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([destination, purpose])
}

/// Identifiers of blocked users — blocks re-registration (docs/02 §2, spec "Blocked Users").
model BlockedIdentity {
  id        String              @id @default(cuid())
  kind      BlockedIdentityKind
  value     String // normalized
  reason    String?
  createdAt DateTime            @default(now())

  @@unique([kind, value])
}

// ─────────────────────────── Staff & RBAC ───────────────────────────
// Effective permissions = union(team permissions) + member grants − member denials.
// Super admins bypass permission checks. (docs/02 §2 module 11)

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     TeamMember[]
  permissions TeamPermission[]
}

model TeamMember {
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([teamId])
}

model TeamPermission {
  teamId     String
  permission String // key from the shared PERMISSIONS catalog

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, permission])
}

/// Per-staff-member override: allow=true grants, allow=false denies (wins over team grants).
model StaffPermission {
  userId     String
  permission String
  allow      Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permission])
}

// ─────────────────────────── Catalogs ───────────────────────────

model Country {
  id         String   @id @default(cuid())
  code       String   @unique // ISO 3166-1 alpha-2
  nameEn     String
  nameAr     String
  priceParam Float    @default(1) // fee-engine country component (C = origin × destination)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  originMissions      Mission[] @relation("missionOrigin")
  destinationMissions Mission[] @relation("missionDestination")
}

model Category {
  id             String   @id @default(cuid())
  nameEn         String
  nameAr         String
  groupEn        String? // Category Group for list views
  groupAr        String?
  typeMultiplier Float    @default(1) // fee-engine T
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  items        Item[]
  tripsAllowed TripCategory[]
  preferences  CategoryPreference[]
}

// ─────────────────────────── Missions ───────────────────────────
// Mission is the supertype (docs/02 decision #2); Trip / Shipment are 1:1 extensions.

enum MissionKind {
  TRIP
  SHIPMENT
}

enum MissionStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  EXPIRED
  CLOSED
}

enum ShipmentKind {
  BOX
  BASKET
}

model Mission {
  id                   String        @id @default(cuid())
  accountId            String
  kind                 MissionKind
  status               MissionStatus @default(ACTIVE)
  isCyclic             Boolean       @default(false) // commercial only (enforced in service)
  originCountryId      String
  destinationCountryId String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  origin      Country @relation("missionOrigin", fields: [originCountryId], references: [id])
  destination Country @relation("missionDestination", fields: [destinationCountryId], references: [id])

  trip          Trip?
  shipment      Shipment?
  dealsAsTrip     Deal[] @relation("dealTrip")
  dealsAsShipment Deal[] @relation("dealShipment")
  matchesAsTrip     Match[] @relation("matchTrip")
  matchesAsShipment Match[] @relation("matchShipment")

  @@index([kind, status, originCountryId, destinationCountryId])
  @@index([accountId])
}

/// Stored trip↔shipment pairing (docs/02 §5) — notification dedup + matched lists.
model Match {
  id                String    @id @default(cuid())
  tripMissionId     String
  shipmentMissionId String
  askFlagged        Boolean   @default(false)
  active            Boolean   @default(true) // false once the pair stops matching
  notifiedAt        DateTime? // both parties notified exactly once
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tripMission     Mission @relation("matchTrip", fields: [tripMissionId], references: [id], onDelete: Cascade)
  shipmentMission Mission @relation("matchShipment", fields: [shipmentMissionId], references: [id], onDelete: Cascade)

  @@unique([tripMissionId, shipmentMissionId])
  @@index([shipmentMissionId])
}

// ── Money: wallet & double-entry ledger (docs/02 §4 — approved) ──
// Integer minor units only. Balances are maintained transactionally with the
// entries and can always be recomputed from them. Corrections = reversing entries.

enum Currency {
  USD
  EGP
}

enum SystemAccount {
  ESCROW // funds frozen for in-flight deals (liability)
  GATEWAY_CLEARING // money in transit from card/Apple Pay gateways (asset)
  COMPANY_BANK // the real bank account backing the ledger (asset)
  WITHDRAWALS_PAYABLE // approved withdrawals awaiting payout (liability)
  PLATFORM_REVENUE // commission/fees/FX spread — 0 at launch (income)
  FX // FX conversion legs
}

enum LedgerTxType {
  DEPOSIT
  WITHDRAWAL_HOLD
  WITHDRAWAL_EXECUTE
  WITHDRAWAL_RELEASE
  TRANSFER
  ESCROW_FUND
  ESCROW_RELEASE
  ESCROW_REFUND
  ESCROW_TOPUP
  ADMIN_ADJUSTMENT
  FX_CONVERT
}

model Wallet {
  id        String   @id @default(cuid())
  accountId String   @unique
  createdAt DateTime @default(now())

  balances WalletBalance[]
  entries  LedgerEntry[]
}

/// Materialized balance per currency — updated in the same transaction as the
/// entries; never edited directly. Negative balances are rejected at post time.
model WalletBalance {
  walletId     String
  currency     Currency
  balanceMinor Int      @default(0)

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@id([walletId, currency])
}

/// One business money movement. Its entries MUST sum to zero per currency.
model LedgerTransaction {
  id          String       @id @default(cuid())
  type        LedgerTxType
  dealId      String?
  actorUserId String?
  note        String?
  createdAt   DateTime     @default(now())

  entries LedgerEntry[]

  @@index([dealId])
  @@index([type, createdAt])
}

/// A single leg: exactly one of walletId / systemAccount is set. Immutable.
model LedgerEntry {
  id            String         @id @default(cuid())
  transactionId String
  walletId      String?
  systemAccount SystemAccount?
  currency      Currency
  amountMinor   Int // signed; positive = credit to this account
  createdAt     DateTime       @default(now())

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  wallet      Wallet?           @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([systemAccount, currency])
}

/// Global fee-engine parameters (docs/02 §4): Fee/item = B·T·(W×kg)·C; Fee/deal = F + Σ.
/// C = origin.priceParam × destination.priceParam; T = category.typeMultiplier.
model FeeConfig {
  id               String   @id @default("GLOBAL")
  basketMultiplier Float    @default(1.3) // B (Box = 1)
  weightUsdPerKg   Int      @default(300) // W in minor units per kg
  floorFeeUsd      Int      @default(500) // F in minor units
  updatedAt        DateTime @updatedAt
}

/// Monthly SMART recalibration output — applied to FeeConfig only after admin approval.
model FeeConfigProposal {
  id              String   @id @default(cuid())
  sampleSize      Int
  ratio           Float // median(agreed / predicted) over completed deals
  proposed        Json // { basketMultiplier, weightUsdPerKg, floorFeeUsd }
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime @default(now())
}

/// Generic admin-editable settings (money limits, FX spread, …).
model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── Deposits / withdrawals / transfers / FX (docs/02 §4) ──

enum DepositMethod {
  INSTAPAY
  BANK_TRANSFER
  // CARD / APPLE_PAY arrive with the gateway adapters (Kashier/OPay credentials)
}

enum DepositStatus {
  REQUESTED // transfer details + order number shown to the user
  PENDING_REVIEW // user submitted the transfer reference
  CONFIRMED
  REJECTED
}

model DepositRequest {
  id              String        @id @default(cuid())
  accountId       String
  currency        Currency
  amountMinor     Int
  method          DepositMethod
  referenceCode   String        @unique // the order number the user puts in the transfer memo
  userReference   String? // the bank/Instapay transaction number the user submits
  status          DepositStatus @default(REQUESTED)
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime      @default(now())

  @@index([status])
  @@index([accountId])
}

model BankAccount {
  id            String   @id @default(cuid())
  accountId     String
  holderName    String
  country       String
  bankName      String
  accountNumber String
  iban          String?
  routingNumber String?
  swift         String?
  holderAddress String?
  createdAt     DateTime @default(now())

  withdrawals WithdrawalRequest[]

  @@index([accountId])
}

enum WithdrawalStatus {
  PENDING // funds held (WITHDRAWAL_HOLD) at request time
  PAID
  REJECTED // hold released
}

model WithdrawalRequest {
  id              String           @id @default(cuid())
  accountId       String
  bankAccountId   String
  currency        Currency
  amountMinor     Int
  status          WithdrawalStatus @default(PENDING)
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime         @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([status])
  @@index([accountId])
}

enum TransferStatus {
  PENDING_OTP // spec O7: transfers re-verify identity by OTP
  SENT
  CANCELLED
}

model Transfer {
  id             String         @id @default(cuid())
  fromAccountId  String
  toAccountId    String
  currency       Currency
  amountMinor    Int
  status         TransferStatus @default(PENDING_OTP)
  otpChallengeId String?
  createdAt      DateTime       @default(now())
  confirmedAt    DateTime?

  @@index([fromAccountId, createdAt])
}

/// Daily USD→EGP rate (free API) — spread applied on top (admin-set, 0 at launch).
model FxRate {
  id        String   @id @default(cuid())
  day       DateTime @unique // truncated to the day
  usdToEgp  Float
  source    String
  createdAt DateTime @default(now())
}

// ── Media (docs/02 §12 — one polymorphic Attachment model) ──

enum AttachmentContext {
  ITEM_PHOTO
  TRIP_VERIFICATION
  CHAT
  KYC
  REVIEW
}

/// Uploaded file: original + compressed + thumbnail variants in MinIO.
/// `isPrivate` gates serving (owner/staff only) — KYC & trip docs are private.
model Attachment {
  id             String            @id @default(cuid())
  ownerAccountId String
  context        AttachmentContext
  subjectId      String // itemId / missionId / messageId / …
  mime           String
  sizeBytes      Int
  isPrivate      Boolean           @default(false)
  createdAt      DateTime          @default(now())

  @@index([context, subjectId])
  @@index([ownerAccountId])
}

/// In-app notifications (email/SMS channels land in Phase 5; push in v2).
model Notification {
  id        String    @id @default(cuid())
  accountId String
  type      String // MATCH | DEAL | ADMIN | ... (admin-extensible catalog in Phase 5)
  title     String?
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, readAt])
  @@index([accountId, createdAt])
}

model Trip {
  missionId         String    @id
  receivingStart    DateTime? // optional → open (shoppers can ship now)
  receivingEnd      DateTime
  tripDate          DateTime // PRIVATE — hidden from other users
  deliveryDate      DateTime
  deliveryLocation  String // destination city/neighbourhood — public on trip detail
  receivingAddress  String // PRIVATE — revealed to the shopper once a deal is dual-agreed
  travelerCount     Int       @default(1)
  availableWeightKg Float // depletes for one-time trips; NOT for cyclic (service logic)
  feeUsd            Int? // asking fee, minor units
  notes             String?

  mission           Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  allowedCategories TripCategory[]
}

enum CategoryStance {
  ACCEPT
  REJECT
  ASK
}

model TripCategory {
  missionId  String
  categoryId String
  stance     CategoryStance @default(ACCEPT) // ASK → matches flagged for traveler confirmation

  trip     Trip     @relation(fields: [missionId], references: [missionId], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([missionId, categoryId])
}

/// Account-level traveler preference per category (Accept / Reject / Ask) —
/// inherited as the default when posting a trip (docs/02 §2).
model CategoryPreference {
  accountId  String
  categoryId String
  stance     CategoryStance

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([accountId, categoryId])
}

model Shipment {
  missionId String       @id
  type      ShipmentKind
  feeUsd    Int? // asking fee, minor units
  notes     String?

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  items   Item[]
}

model Item {
  id                 String  @id @default(cuid())
  shipmentId         String
  details            String
  url                String?
  volumetricWeightKg Float // single collected figure (docs decision 2026-06-25)
  count              Int     @default(1)
  categoryId         String
  declaredValueUsd   Int? // minor units, USD (Box)
  notes              String?

  shipment Shipment @relation(fields: [shipmentId], references: [missionId], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([shipmentId])
}

// ─────────────────────────── Deals ───────────────────────────

enum DealStatus {
  REQUESTED
  NEGOTIATING
  ONGOING
  ARRIVED_DESTINATION
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum OngoingStep {
  ORDERED
  SHIPPED
  DELIVERED_TO_TRAVELER
  RECEIVED_BY_TRAVELER
}

enum PaymentMethod {
  CASH
  IN_APP
}

/// Basket pricing (decision L2): FIXED = all-inclusive price, traveler bears risk;
/// VARIABLE = actual costs + fee, shopper bears risk (estimate reconciled at completion).
enum PricingMode {
  FIXED
  VARIABLE
}

model Deal {
  id                   String        @id @default(cuid())
  tripMissionId        String
  shipmentMissionId    String
  travelerAccountId    String
  shopperAccountId     String
  requestedByAccountId String
  lastOfferByAccountId String // accept must come from the other party
  status               DealStatus    @default(REQUESTED)
  ongoingStep          OngoingStep?
  paymentMethod        PaymentMethod @default(CASH)
  feeUsd               Int // agreed fee, minor units (FIXED baskets: all-inclusive price)
  pricingMode          PricingMode? // BASKET only; null for BOX
  actualPriceUsd       Int? // VARIABLE baskets: actual product cost set by the traveler
  escrowedUsd          Int           @default(0) // currently held in escrow for this deal
  completedAt          DateTime? // drives the review window (+12h … +12d)
  travelerPaysAllCustoms Boolean     @default(false) // exempts the deal from trip-level CUSTOMS flags
  cancelReason         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tripMission     Mission @relation("dealTrip", fields: [tripMissionId], references: [id])
  shipmentMission Mission @relation("dealShipment", fields: [shipmentMissionId], references: [id])
  travelerAccount Account @relation("travelerDeals", fields: [travelerAccountId], references: [id])
  shopperAccount  Account @relation("shopperDeals", fields: [shopperAccountId], references: [id])

  events              DealEvent[]
  flags               DealFlag[]
  resolution          DealResolution?
  cancellationRequest CancellationRequest?

  @@unique([tripMissionId, shipmentMissionId])
  @@index([travelerAccountId])
  @@index([shopperAccountId])
  @@index([status])
}

// ── Flags, resolutions & staff cancellation queue (docs/02 §3) ──

enum DealFlagType {
  DELAYED
  CUSTOMS
  PARTIALLY
}

enum PartialProblem {
  LOST_DAMAGED
  DELAYED
}

model DealFlag {
  id        String         @id @default(cuid())
  dealId    String
  type      DealFlagType
  problem   PartialProblem? // set for PARTIALLY
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  clearedAt DateTime?

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, type])
}

enum ResolutionStatus {
  PROPOSED
  APPROVED
}

/// "How was the deal completed?" — dual-approval; required before COMPLETED when
/// the deal carries a PARTIALLY or CUSTOMS flag (the green flag).
model DealResolution {
  id                  String           @id @default(cuid())
  dealId              String           @unique
  text                String
  proposedByAccountId String // an edit moves proposership — the other party must approve
  status              ResolutionStatus @default(PROPOSED)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

enum CancellationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Edit approvals (docs/02 §2 — ChangeRequest) ──

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Approval-gated edits (trip dates now; display/full name with the profile module).
/// Shows staff exactly what changed: before → after.
model ChangeRequest {
  id              String              @id @default(cuid())
  accountId       String
  subjectType     String // 'TRIP_DATES' | 'DISPLAY_NAME' | 'FULL_NAME' | ...
  subjectId       String // e.g. missionId
  before          Json
  after           Json
  status          ChangeRequestStatus @default(PENDING)
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime            @default(now())

  @@index([status, subjectType])
  @@index([subjectId])
}

/// Shopper cancellations at Ordered-or-later require staff approval before execution.
model CancellationRequest {
  id                   String             @id @default(cuid())
  dealId               String             @unique
  requestedByAccountId String
  reason               String
  status               CancellationStatus @default(PENDING)
  decidedByUserId      String?
  decidedAt            DateTime?
  createdAt            DateTime           @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([status])
}

/// Append-only history of everything that happens on a deal (negotiation log included).
model DealEvent {
  id          String   @id @default(cuid())
  dealId      String
  actorUserId String?
  type        String
  data        Json?
  createdAt   DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}
