# ─────────────────────────────────────────────────────────────────────────────
# Sindbad production environment — copy to `.env` on the server and fill in.
# Compose reads this file automatically (`docker compose --env-file .env`).
# NEVER commit the real .env. Generate every secret with `openssl rand -hex 32`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains (point A/AAAA records at the VPS; see docs/06-deployment.md) ──
WEB_DOMAIN=sindbad.app
ADMIN_DOMAIN=admin.sindbad.app
API_DOMAIN=api.sindbad.app
ACME_EMAIL=ops@sindbad.app

# ── Public API URL (baked into the browser bundle at build time) ──
NEXT_PUBLIC_API_URL=https://api.sindbad.app

# ── Postgres ──
POSTGRES_USER=sindbad
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=sindbad
DATABASE_URL=postgresql://sindbad:CHANGE_ME_strong_db_password@postgres:5432/sindbad?schema=public

# ── Redis (Socket.IO adapter + future caching) ──
REDIS_URL=redis://redis:6379

# ── Auth ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL_SEC=900
# Reverse-proxy hops in front of the API, so rate limiting sees the real client IP.
# 1 = Traefik only (current). Set to 2 once Cloudflare proxying (orange cloud) is on.
TRUST_PROXY_HOPS=1

# ── CORS — the browser origins allowed to call the API with credentials ──
CORS_ORIGINS=https://sindbad.app,https://www.sindbad.app,https://admin.sindbad.app

# ── Object storage (MinIO, reached only from inside the compose network) ──
MINIO_ROOT_USER=sindbad
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=sindbad

# ── First super-admin (seeded once by the migrate one-shot) ──
SEED_ADMIN_EMAIL=admin@sindbad.app
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Email (SMTP) — REQUIRED for real OTP/email delivery ──
# Works with any transactional service (Amazon SES, Resend, Brevo, Mailgun,
# Postmark, …) or a self-hosted server. Leave SMTP_HOST empty to log codes only.
# SMTP_HOST=email-smtp.eu-north-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true only for port 465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Sindbad <no-reply@sindbad.app>

# ── SMS — SMS Misr (+20 numbers) + Twilio (international) ──
# When both are set, Egyptian numbers go via SMS Misr and the rest via Twilio.
# SMS Misr — sender name must be NTRA-approved on the account.
# SMSMISR_USERNAME=
# SMSMISR_PASSWORD=
# SMSMISR_SENDER=
# SMSMISR_ENVIRONMENT=1       # 1 = live, 2 = test
# Twilio (international)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=                # a Twilio number (+1…) or Messaging Service SID (MG…)

# ── Payment gateways (CARD deposits) — each activates when its keys are set ──
# PUBLIC_WEB_URL is where the gateway returns the user; the webhook URL is derived
# from NEXT_PUBLIC_API_URL. Confirm exact API details with each provider's dashboard.
# PUBLIC_WEB_URL=https://sindbad.app
# Kashier
# KASHIER_MERCHANT_ID=
# KASHIER_API_KEY=
# KASHIER_MODE=live            # live | test
# OPay
# OPAY_MERCHANT_ID=
# OPAY_PUBLIC_KEY=
# OPAY_SECRET_KEY=
# OPAY_BASE_URL=https://api.opaycheckout.com
